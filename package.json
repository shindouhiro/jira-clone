    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/tabler": "^1.2.33",
    "eslint": "catalog:dev",
    "eslint-plugin-format": "^2.0.1",
    "lint-staged": "^15.4.1",
    "simple-git-hooks": "^2.11.1",
    "typescript": "catalog:dev"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
